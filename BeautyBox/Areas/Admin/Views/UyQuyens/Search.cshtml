@model PagedList.IPagedList<BeautyBox.Models.Credential>
@using PagedList.Mvc;
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_AdminPageStart")
            @Html.Partial("_AdminListToolbar", null, new ViewDataDictionary {
                { "ListTitle", "Danh sách ủy quyền" },
                { "ListController", "UyQuyens" },
                { "SearchPlaceholder", "Tìm kiếm ủy quyền" },
                { "ShowCreate", true }
            })
            <div id="search__result">Có <text>@ViewData["Count"]</text> ủy quyền phù hợp với từ khóa: <text>@ViewBag.CurrentFilter</text></div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã ủy quyền</th>
                            <th>Tên loại tài khoản</th>
                            <th>Tên vai trò</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.CredentialID</td>
                                <td>@item.Role.Name</td>
                                <td>@item.UserGroup.Name</td>
                                <td>
                                    @Html.Partial("_AdminTableActions", null, new ViewDataDictionary {
                                        { "DetailsUrl", Url.Action("Details", "UyQuyens", new { id = item.CredentialID }) },
                                        { "EditUrl", Url.Action("Edit", "UyQuyens", new { id = item.CredentialID }) },
                                        { "DeleteCssClass", "delBtnUQ" },
                                        { "DeleteId", item.CredentialID }
                                    })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="admin-pagination phan-trang">@Html.PagedListPager(Model, page => Url.Action("Index", new { page }))</div>
@Html.Partial("_AdminPageEnd")
@section ajaxDel2{
    <script src="~/Areas/Admin/assets/js/delete2.js"></script>
}