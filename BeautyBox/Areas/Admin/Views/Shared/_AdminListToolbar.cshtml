@{
    var listTitle = ViewData["ListTitle"] as string ?? "Danh sách";
    var listController = ViewData["ListController"] as string ?? "";
    var searchPlaceholder = ViewData["SearchPlaceholder"] as string ?? "Tìm kiếm";
    var showCreate = ViewData["ShowCreate"] as bool? ?? true;
    var createAction = ViewData["CreateAction"] as string ?? "Create";
}
<div class="admin-toolbar">
    <div>
        <h4 class="admin-toolbar__title">@listTitle</h4>
        <span class="admin-toolbar__subtitle">Quản lý dữ liệu Beauty Box</span>
    </div>
    <div class="admin-toolbar__actions">
        @if (!string.IsNullOrEmpty(listController))
        {
            <div class="admin-toolbar__search">
                @using (Html.BeginForm("Search", listController))
                {
                    <input type="text" placeholder="@searchPlaceholder" id="SearchString" name="SearchString" />
                    <button type="submit" onclick="return valid_search();" aria-label="Tìm kiếm">
                        <i class="fas fa-search"></i>
                    </button>
                }
            </div>
        }
        @if (showCreate && !string.IsNullOrEmpty(listController))
        {
            <a class="btn btn-primary btn-admin-add" href="@Url.Action(createAction, listController)">
                <i class="fas fa-plus"></i> Thêm mới
            </a>
        }
    </div>
</div>
