@{
    var pageTitle = ViewData["PageTitle"] as string ?? ViewBag.Title as string;
    var subtitle = ViewData["PageSubtitle"] as string;
}
@if (!string.IsNullOrEmpty(pageTitle))
{
    <div class="admin-page-header">
        <h2>@pageTitle</h2>
        @if (!string.IsNullOrEmpty(subtitle))
        {
            <p class="text-muted mb-0">@subtitle</p>
        }
    </div>
}
