
@{
    ViewBag.Title = "Trang chủ quản trị";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var session = (BeautyBox.Common.UserLogin)Session[BeautyBox.Common.CommonConstants.USER_SESSION];
}

<div class="admin-dashboard">
    <div class="admin-welcome">
        <div class="admin-welcome__brand">
            <img src="~/assets/img/logo.png" alt="Beauty Box" />
            <div>
                <h1 class="admin-welcome__heading">Bảng điều khiển Beauty Box</h1>
                <p class="admin-welcome__tagline">Beauty Box — Quản lý sản phẩm, đơn hàng và khách hàng tập trung một nơi.</p>
            </div>
        </div>
        @if (session != null)
        {
            <div class="admin-welcome__user">
                <div>
                    <div class="admin-welcome__name">@session.HoTen</div>
                    <div class="admin-welcome__date">@DateTime.Now.ToString("dddd, dd/MM/yyyy")</div>
                </div>
                <img src="~/assets/Images/AnhDaiDien/@session.AnhDaiDien" alt="@session.HoTen" class="admin-welcome__avatar" />
                <img src="~/Areas/Admin/assets/images/qrcode_beautybox.com.vn.png" alt="QR Beauty Box" class="admin-welcome__qr" />
            </div>
        }
    </div>

    <div class="admin-stats">
        <a href="@Url.Action("Index", "SanPhams")" class="admin-stat-card">
            <div class="admin-stat-card__icon"><i class="fas fa-box-open"></i></div>
            <div class="admin-stat-card__value">@ViewBag.CountSanPham</div>
            <div class="admin-stat-card__label">Sản phẩm</div>
        </a>
        <a href="@Url.Action("Index", "HoaDons")" class="admin-stat-card">
            <div class="admin-stat-card__icon"><i class="fas fa-file-invoice-dollar"></i></div>
            <div class="admin-stat-card__value">@ViewBag.CountHoaDon</div>
            <div class="admin-stat-card__label">Hóa đơn</div>
        </a>
        <a href="@Url.Action("Index", "NguoiDungs")" class="admin-stat-card">
            <div class="admin-stat-card__icon"><i class="fas fa-users"></i></div>
            <div class="admin-stat-card__value">@ViewBag.CountNguoiDung</div>
            <div class="admin-stat-card__label">Tài khoản</div>
        </a>
        <a href="@Url.Action("Index", "TinTucs")" class="admin-stat-card">
            <div class="admin-stat-card__icon"><i class="fas fa-newspaper"></i></div>
            <div class="admin-stat-card__value">@ViewBag.CountTinTuc</div>
            <div class="admin-stat-card__label">Tin tức</div>
        </a>
    </div>

    <h3 class="admin-section-title">Truy cập nhanh</h3>
    <div class="admin-quick-links">
        <a href="@Url.Action("Index", "DanhMucs")" class="admin-quick-link"><i class="fas fa-th-large"></i> Danh mục</a>
        <a href="@Url.Action("Index", "LoaiSPs")" class="admin-quick-link"><i class="fas fa-tags"></i> Loại SP</a>
        <a href="@Url.Action("Index", "SanPhams")" class="admin-quick-link"><i class="fas fa-shopping-bag"></i> Sản phẩm</a>
        <a href="@Url.Action("Index", "TinTucs")" class="admin-quick-link"><i class="fas fa-rss"></i> Tin tức</a>
        <a href="@Url.Action("Index", "HoaDons")" class="admin-quick-link"><i class="fas fa-receipt"></i> Hóa đơn</a>
        <a href="@Url.Action("Index", "NguoiDungs")" class="admin-quick-link"><i class="fas fa-user-circle"></i> Tài khoản</a>
    </div>

    <div class="admin-widget">
        <div class="admin-widget__head">
            <span><i class="fas fa-fire"></i></span>
            <h4>Sản phẩm bán chạy</h4>
        </div>
        <div class="admin-widget__body">
            <div class="admin-bestseller-grid">
                @foreach (var product in ViewBag.SanPhamBanChay)
                {
                    <div class="admin-bestseller-item">
                        <a href="@Url.Action("Details", "SanPhams", new { id = product.MaSP })">
                            <img src="~/assets/Images/SanPham/@product.AnhDaiDien" alt="@product.TenSP" />
                        </a>
                        <h3 class="admin-bestseller-item__title">
                            <a href="@Url.Action("Details", "SanPhams", new { id = product.MaSP })">@product.TenSP</a>
                        </h3>
                        <div class="admin-bestseller-item__price">
                            @if (product.KhuyenMai == 0)
                            {
                                @(string.Format("{0:c0}", product.Gia))
                            }
                            else
                            {
                                @(string.Format("{0:c0}", product.Gia - product.Gia * product.KhuyenMai / 100))
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
