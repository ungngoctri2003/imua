@model PagedList.IPagedList<BeautyBox.Models.NguoiDung>
@using PagedList.Mvc;
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_AdminPageStart")
            @Html.Partial("_AdminListToolbar", null, new ViewDataDictionary {
                { "ListTitle", "Danh sách tài khoản" },
                { "ListController", "NguoiDungs" },
                { "SearchPlaceholder", "Tìm kiếm khách hàng" },
                { "ShowCreate", false }
            })
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Họ tên</th>
                            <th>Số điện thoại</th>
                            <th>Địa chỉ</th>
                            <th>Email</th>
                            <th>Loại tài khoản</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.HoTen</td>
                                <td>@item.SoDT</td>
                                <td>@item.DiaChi</td>
                                <td>@item.Email</td>
                                <td>
                                    @if (item.GroupID == "MEMBER")
                                    {
                                        <span>Khách hàng</span>
                                    }
                                    else if (item.GroupID == "ADMIN")
                                    {
                                        <span>Quản trị</span>
                                    }
                                    else
                                    {
                                        <span>@item.GroupID</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("ChangeStatus","NguoiDungs",new { id = item.MaND })" class="admin-status-link">
                                        @if (item.TrangThai.Equals(false))
                                        {
                                            <span class="admin-badge admin-badge--inactive">Ngưng hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="admin-badge admin-badge--active">Đang hoạt động</span>
                                        }
                                    </a>
                                    @Html.HiddenFor(model => item.MaND)
                                </td>
                                <td>
                                    @Html.Partial("_AdminTableActions", null, new ViewDataDictionary {
                                        { "DetailsUrl", Url.Action("Details", "NguoiDungs", new { id = item.MaND }) },
                                        { "ShowEdit", false },
                                        { "ShowDelete", false }
                                    })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="admin-pagination phan-trang">@Html.PagedListPager(Model, page => Url.Action("Index", new { page }))</div>
@Html.Partial("_AdminPageEnd")
