@model BeautyBox.Models.NguoiDung

@{
    ViewBag.Title = "Thông tin tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var imagePath = "~/assets/Images/AnhDaiDien/" + Model.AnhDaiDien;
}

@Html.Partial("_AdminPageStart")
<div class="admin-form-profile" style="max-width:520px;margin:0 auto;">
            <h3 class="elements-header">Hồ sơ của bạn</h3>
            @Html.ValidationSummary(true, "", new { @class = "admin-alert admin-alert--error" })

            @using (Html.BeginForm("ChangeInfor", "NguoiDungs", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.MaND)
                @Html.HiddenFor(model => model.MatKhau)
                @Html.HiddenFor(model => model.TrangThai)
                @Html.HiddenFor(model => model.GroupID)
                @Html.HiddenFor(model => model.TenDangNhap)
                <input type="hidden" name="Image1" value="@Model.AnhDaiDien" />

                <div class="text-center mb-4">
                    @if (string.IsNullOrEmpty(Model.AnhDaiDien))
                    {
                        <img id="output" src="~/assets/Images/AnhDaiDien/default-avatar.png" alt="avatar" style="width: 12rem; height: 12rem; border-radius: 50%; object-fit: cover; border: 2px solid var(--color-border);" />
                    }
                    else
                    {
                        <img id="output" src="@Url.Content(imagePath)" alt="avatar" style="width: 12rem; height: 12rem; border-radius: 50%; object-fit: cover; border: 2px solid var(--color-border);" />
                    }
                    <p class="mt-2">
                        <label for="ufile" class="modal-label" style="cursor: pointer; display: inline-block; padding: 0.5rem 1rem;">Chọn ảnh đại diện</label>
                        <input type="file" name="ImageFile" id="ufile" style="display: none;" onchange="loadFile(event)" />
                    </p>
                </div>

                <div class="form-group">
                    <label>Họ và tên</label>
                    @Html.TextBoxFor(model => model.HoTen, new { @class = "form-control", placeholder = "Họ và tên" })
                    @Html.ValidationMessageFor(model => model.HoTen, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    <label>Email</label>
                    @Html.TextBoxFor(model => model.Email, new { @class = "form-control", placeholder = "Email" })
                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    <label>Số điện thoại</label>
                    @Html.TextBoxFor(model => model.SoDT, new { @class = "form-control", placeholder = "Số điện thoại" })
                    @Html.ValidationMessageFor(model => model.SoDT, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    <label>Địa chỉ</label>
                    @Html.TextBoxFor(model => model.DiaChi, new { @class = "form-control", placeholder = "Địa chỉ" })
                    @Html.ValidationMessageFor(model => model.DiaChi, "", new { @class = "text-danger" })
                </div>
                <button type="submit" class="btn btn-primary btn-block">Lưu thay đổi</button>
            }
</div>
@Html.Partial("_AdminPageEnd")

@if (ViewBag.Success != null)
{
    <script>alert('Thay đổi thông tin thành công');</script>
}

<script>
    var loadFile = function (event) {
        document.getElementById('output').src = URL.createObjectURL(event.target.files[0]);
    };
</script>
