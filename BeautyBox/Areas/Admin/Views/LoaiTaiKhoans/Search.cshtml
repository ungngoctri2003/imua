@model PagedList.IPagedList<BeautyBox.Models.UserGroup>
@using PagedList.Mvc;
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_AdminPageStart")
            @Html.Partial("_AdminListToolbar", null, new ViewDataDictionary {
                { "ListTitle", "Danh sách loại tài khoản" },
                { "ListController", "LoaiTaiKhoans" },
                { "SearchPlaceholder", "Tìm kiếm loại tài khoản" },
                { "ShowCreate", true }
            })
            <div id="search__result">Có <text>@ViewData["Count"]</text> loại tài khoản phù hợp với từ khóa: <text>@ViewBag.CurrentFilter</text></div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã loại tài khoản</th>
                            <th>Tên loại tài khoản</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.GroupID</td>
                                <td>@item.Name</td>
                                <td>
                                    @Html.Partial("_AdminTableActions", null, new ViewDataDictionary {
                                        { "DetailsUrl", Url.Action("Details", "LoaiTaiKhoans", new { id = item.GroupID }) },
                                        { "EditUrl", Url.Action("Edit", "LoaiTaiKhoans", new { id = item.GroupID }) },
                                        { "DeleteCssClass", "delBtnLTK" },
                                        { "DeleteId", item.GroupID }
                                    })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="admin-pagination phan-trang">@Html.PagedListPager(Model, page => Url.Action("Index", new { page }))</div>
@Html.Partial("_AdminPageEnd")
@section ajaxDel{
    <script src="~/Areas/Admin/assets/js/delete.js"></script>
}