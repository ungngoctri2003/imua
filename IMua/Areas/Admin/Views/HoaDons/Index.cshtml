@model PagedList.IPagedList<IMua.Models.HoaDon>
@using PagedList.Mvc;
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_AdminPageStart")
            @Html.Partial("_AdminListToolbar", null, new ViewDataDictionary {
                { "ListTitle", "Danh sách hoá đơn" },
                { "ListController", "HoaDons" },
                { "SearchPlaceholder", "Tìm kiếm hoá đơn" },
                { "ShowCreate", false }
            })
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã hoá đơn</th>
                            <th>Ngày mua</th>
                            <th>Người dùng</th>
                            <th>Thành tiền</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaHD</td>
                                <td>@item.NgayMua</td>
                                <td>@item.NguoiDung.HoTen</td>
                                <td>@string.Format("{0:c0}", item.ThanhTien)</td>
                                <td>
                                    @Html.Partial("_AdminTableActions", null, new ViewDataDictionary {
                                        { "DetailsUrl", Url.Action("Details", "HoaDons", new { id = item.MaHD }) },
                                        { "ShowEdit", false },
                                        { "DeleteCssClass", "delBtnHD" },
                                        { "DeleteId", item.MaHD }
                                    })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="admin-pagination phan-trang">@Html.PagedListPager(Model, page => Url.Action("Index", new { page }))</div>
@Html.Partial("_AdminPageEnd")
@section ajaxDel{
    <script src="~/Areas/Admin/assets/js/delete.js"></script>
}
