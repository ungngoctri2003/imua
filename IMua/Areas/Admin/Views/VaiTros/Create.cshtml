@model IMua.Models.Role

@{
    ViewBag.Title = "Create";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.Partial("_AdminPageStart")
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        
                <h3 class="elements-header">Thêm mới vai trò</h3>
                <br />
                <div class="table-responsive">
                    <table class="table table-hover">
                        <tr>
                            <td>
                                <label class="elements-title">Mã vai trò :</label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @Html.EditorFor(model => model.RoleID, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.RoleID, "", new { @class = "text-danger" })
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="elements-title">Tên vai trò :</label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control" } })
                                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
                            </td>
                        </tr>
                    </table>
                </div>
                <input type="submit" value="Thêm" class="btn btn-outline-warning btn-fw" />
                <button class="btn btn-inverse-dark btn-fw" onclick="location.href='@Url.Action("Index", "VaiTros")';return false;">Hủy</button>
@Html.Partial("_AdminPageEnd")
}