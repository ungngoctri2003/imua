@using IMua.Models
@using System.Linq

@{
    ViewBag.Title = "Chi tiết tin tức";
    Layout = "~/Views/Shared/_Layout.cshtml";

    TinTuc article = null;
    var model = ViewData.Model;

    if (model is TinTuc singleArticle)
    {
        article = singleArticle;
    }
    else if (model is IEnumerable<TinTuc> articles)
    {
        article = articles.FirstOrDefault();
    }

    ViewBag.Title = article?.TieuDe ?? "Chi tiết tin tức";

    var relatedNews = ViewBag.RelatedNews as IEnumerable<TinTuc> ?? Enumerable.Empty<TinTuc>();
    var plainText = HttpUtility.HtmlDecode(article?.NoiDung ?? "");
    var wordCount = string.IsNullOrWhiteSpace(plainText)
        ? 0
        : plainText.Split(new[] { ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries).Length;
    var readMinutes = Math.Max(1, (int)Math.Ceiling(wordCount / 180.0));
}

<div class="news-detail-page">
    <div class="container">
        <div class="detail__path breadcrumb reveal">
            <a href="@Url.Action("Index", "Home")">Trang chủ</a>
            <span class="breadcrumb__sep">/</span>
            <a href="@Url.Action("ListNews", "Home")">Tin nổi bật</a>
            <span class="breadcrumb__sep">/</span>
            <span>Chi tiết tin</span>
        </div>

        @if (article != null)
        {
            <div class="news-detail reveal">
                <div class="news-detail__toolbar no-print">
                    <a href="@Url.Action("ListNews", "Home")" class="news-detail__back">
                        <i class="fas fa-arrow-left"></i> Quay lại tin tức
                    </a>
                    <button type="button" class="news-detail__share" onclick="window.print()">
                        <i class="fas fa-print"></i> In bài viết
                    </button>
                </div>

                <div class="news-detail__layout">
                    <article class="news-detail__article">
                        <header class="news-detail__hero">
                            <div class="news-detail__hero-media">
                                <img src="~/assets/Images/TinTuc/@article.AnhTinTuc" alt="@article.TieuDe">
                                <span class="news-detail__badge">
                                    <i class="fas fa-newspaper"></i> Tin làm đẹp
                                </span>
                            </div>

                            <div class="news-detail__hero-content">
                                <h1 class="news-detail__title">@article.TieuDe</h1>

                                <p class="news-detail__summary">
                                    @Html.Raw(HttpUtility.HtmlDecode(article.TomTat))
                                </p>

                                <div class="news-detail__meta">
                                    <span class="news-detail__meta-item">
                                        <i class="fas fa-hashtag"></i>
                                        Bài @article.MaTinTuc.ToString("D3")
                                    </span>
                                    <span class="news-detail__meta-item">
                                        <i class="fas fa-clock"></i>
                                        @readMinutes phút đọc
                                    </span>
                                    <span class="news-detail__meta-item">
                                        <i class="fas fa-book-open"></i>
                                        IMUA Beauty News
                                    </span>
                                </div>
                            </div>
                        </header>

                        <div class="news-detail__body">
                            @Html.Raw(HttpUtility.HtmlDecode(article.NoiDung))
                        </div>

                        <footer class="news-detail__footer">
                            <div class="news-detail__note">
                                <i class="fas fa-leaf"></i>
                                <p>IMUA cam kết mang đến những thông tin làm đẹp chính xác, cập nhật xu hướng mới nhất cho bạn.</p>
                            </div>

                            <div class="news-detail__actions no-print">
                                <a href="@Url.Action("ListNews", "Home")" class="news-detail__btn news-detail__btn--outline">
                                    <i class="fas fa-list"></i> Xem thêm tin
                                </a>
                                <a href="@Url.Action("Index", "Home")" class="news-detail__btn news-detail__btn--primary">
                                    <i class="fas fa-shopping-bag"></i> Mua sắm ngay
                                </a>
                            </div>
                        </footer>
                    </article>

                    @if (relatedNews.Any())
                    {
                        <aside class="news-detail__sidebar no-print">
                            <div class="news-detail__sidebar-card">
                                <h2 class="news-detail__sidebar-title">
                                    <i class="fas fa-fire"></i> Tin liên quan
                                </h2>

                                <div class="news-detail__related-list">
                                    @foreach (var item in relatedNews)
                                    {
                                        <a href="@Url.Action("NewsDetail", "Home", new { id = item.MaTinTuc })" class="news-detail__related-item">
                                            <span class="news-detail__related-thumb">
                                                <img src="~/assets/Images/TinTuc/@item.AnhTinTuc" alt="@item.TieuDe">
                                            </span>
                                            <span class="news-detail__related-info">
                                                <strong>@item.TieuDe</strong>
                                                <span>@Html.Raw(HttpUtility.HtmlDecode(item.TomTat))</span>
                                            </span>
                                        </a>
                                    }
                                </div>

                                <a href="@Url.Action("ListNews", "Home")" class="news-detail__sidebar-link">
                                    Xem tất cả tin tức <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </aside>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="cart-empty-state reveal">
                <div class="cart-empty-state__icon"><i class="fas fa-newspaper"></i></div>
                <h2>Không tìm thấy bài viết</h2>
                <p>Bài viết bạn tìm kiếm không tồn tại hoặc đã bị gỡ.</p>
                <a href="@Url.Action("ListNews", "Home")" class="button btn-primary">Quay lại tin tức</a>
            </div>
        }
    </div>
</div>
