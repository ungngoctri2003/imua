<div class="banner banner--hero reveal">
    <div class="container">
        <div class="banner__img banner__img--hero">
            <a href="@Url.Action("ListProductSaleOff", "Home")">
                <img src="~/assets/img/mua-xuan-2020-0.jpg" alt="Khuyến mãi mùa xuân">
                <div class="banner__overlay">
                    <span class="banner__tag">Khuyến mãi đặc biệt</span>
                    <h2 class="banner__heading">Mỹ phẩm chính hãng<br><em>Sale off đến 50%</em></h2>
                    <p class="banner__desc">Hàng ngàn sản phẩm chất lượng — Mua là có quà tặng kèm</p>
                    <span class="banner__cta">Khám phá ngay <i class="fas fa-arrow-right"></i></span>
                </div>
            </a>
        </div>
        @Html.Partial("_ServiceBar")
    </div>
</div>

<div class="stats-bar reveal">
    <div class="container">
        <div class="stats-bar__wrapper stagger-children">
            <div class="stats-bar__card">
                <div class="stats-bar__icon" aria-hidden="true">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stats-bar__content">
                    <div class="stats-bar__value">
                        <span class="stats-bar__number" data-count="10000">0</span><span class="stats-bar__suffix">+</span>
                    </div>
                    <span class="stats-bar__label">Khách hàng tin tưởng</span>
                </div>
            </div>
            <div class="stats-bar__card">
                <div class="stats-bar__icon" aria-hidden="true">
                    <i class="fas fa-box-open"></i>
                </div>
                <div class="stats-bar__content">
                    <div class="stats-bar__value">
                        <span class="stats-bar__number" data-count="5000">0</span><span class="stats-bar__suffix">+</span>
                    </div>
                    <span class="stats-bar__label">Sản phẩm chính hãng</span>
                </div>
            </div>
            <div class="stats-bar__card">
                <div class="stats-bar__icon" aria-hidden="true">
                    <i class="fas fa-tags"></i>
                </div>
                <div class="stats-bar__content">
                    <div class="stats-bar__value">
                        <span class="stats-bar__number" data-count="50">0</span><span class="stats-bar__suffix">%</span>
                    </div>
                    <span class="stats-bar__label">Sale off tối đa</span>
                </div>
            </div>
            <div class="stats-bar__card">
                <div class="stats-bar__icon" aria-hidden="true">
                    <i class="fas fa-truck"></i>
                </div>
                <div class="stats-bar__content">
                    <div class="stats-bar__value">
                        <span class="stats-bar__number" data-count="63">0</span><span class="stats-bar__suffix stats-bar__suffix--unit">tỉnh</span>
                    </div>
                    <span class="stats-bar__label">Giao hàng toàn quốc</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="best__seller reveal">
    @{ ViewBag.SectionTitle = "sản phẩm bán chạy"; ViewBag.SectionSubtitle = "Những sản phẩm được yêu thích nhất"; }
    @Html.Partial("_SectionTitle")
    <div class="product-grid container stagger-children">
        @foreach (IMua.Models.SanPhamBanChay item in ViewBag.SanPhamBanChay)
        {
            @Html.Partial("_ProductCard", IMua.Models.ProductCardViewModel.From(item))
        }
    </div>
</div>

@{ var categoryIndex = 0; }
@foreach (var item in ViewBag.DanhMuc)
{
    <div class="category reveal @(categoryIndex % 2 == 1 ? "category--alt" : "")">
    @{ categoryIndex++; }
        <div class="category__nav">
            <a href="@Url.Action("Index", "Category",new { id = item.MaDM })">
                <h2>@item.TenDM</h2>
            </a>
            <div class="navbar">
                <ul>
                    @foreach (var subitem in item.LoaiSPs)
                    {
                        <li><a href="@Url.Action("ProductType", "Home",new { id = subitem.MaLoai })" class="btnItem">@subitem.TenLoai</a></li>
                    }
                </ul>
            </div>
            <a href="@Url.Action("Index", "Category",new { id = item.MaDM })" class="category__more">Xem thêm</a>
        </div>
        <div class="category__content">
            <div class="container">
                <div class="content__left">
                    <div class="content__banner">
                        <a href="@Url.Action("Index", "Category",new { id = item.MaDM })">
                            @if (item.MaDM == 1)
                            {
                                <img src="~/assets/img/my-pham-trang-diem-menu-left.jpg" alt="@item.TenDM">
                            }
                            else if (item.MaDM == 2)
                            {
                                <img src="~/assets/img/ho-tro-dieu-tri-menu-left.jpg" alt="@item.TenDM">
                            }
                            else if (item.MaDM == 3)
                            {
                                <img src="~/assets/img/cham-soc-da-mat-menu-left.jpg" alt="@item.TenDM">
                            }
                            else
                            {
                                <img src="~/assets/img/cham-soc-toan-than-menu-left.jpg" alt="@item.TenDM">
                            }
                        </a>
                    </div>
                </div>
                @{ Html.RenderAction("Product", "Home", new { MaDM = @item.MaDM });}
            </div>
        </div>
    </div>
}

<div class="banner reveal">
    <div class="container">
        <div class="banner__img">
            <a href="@Url.Action("Contact", "Home")">
                <img src="~/assets/img/100-hai-long-3.jpg" alt="Cam kết 100% hài lòng">
            </a>
        </div>
    </div>
</div>

<div class="news reveal">
    @{ ViewBag.SectionTitle = "Tin nổi bật"; ViewBag.SectionSubtitle = "Cập nhật xu hướng làm đẹp mới nhất"; ViewBag.SectionLinkText = "Xem tất cả"; ViewBag.SectionLinkUrl = Url.Action("ListNews", "Home"); }
    @Html.Partial("_SectionTitle")
    <div class="product-grid container stagger-children news__grid">
        @foreach (var item in ViewBag.TinTuc)
        {
            <article class="product news-card">
                <div class="product__thumb">
                    <a href="@Url.Action("NewsDetail", "Home", new { id = item.MaTinTuc })" class="product__img">
                        <img src="~/assets/Images/TinTuc/@item.AnhTinTuc" alt="@item.TieuDe" />
                        <span class="news-card__overlay"><i class="fas fa-book-open"></i></span>
                    </a>
                </div>
                <div class="product__info">
                    <h3 class="product__title">
                        <a href="@Url.Action("NewsDetail", "Home", new { id = item.MaTinTuc })">@item.TieuDe</a>
                    </h3>
                    <div class="product__subtitle">
                        <p>@item.TomTat</p>
                    </div>
                    <a href="@Url.Action("NewsDetail", "Home", new { id = item.MaTinTuc })" class="news-card__readmore">
                        Đọc thêm <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </article>
        }
    </div>
</div>
