@{
    var session = (IMua.Common.UserLogin)Session[IMua.Common.CommonConstants.USER_SESSION];
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IMUA - Mỹ phẩm online chính hãng, Cam kết chất lượng, Mua là có quà</title>
    <link rel="shortcut icon" href="~/assets/img/iconlogo.ico" type="image/x-icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.2/css/all.min.css"
          integrity="sha512-HK5fgLBL+xu6dm/Ii3z4xhlSUyZgTT9tuc/hSrtw6uzJOvgRr2a9jyxxT1ely+B+xFAmJKVSTbpM/CuL7qxO8w=="
          crossorigin="anonymous" />
    <link href="~/assets/fonts/material-icon/css/material-design-iconic-font.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/assets/css/reset.css">
    <link href="~/assets/css/AddCSS.css" rel="stylesheet" />
    <link href="~/assets/css/Cart.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/assets/css/premium-home.css">
    <link rel="stylesheet" href="~/assets/css/animations.css">
    <link rel="stylesheet" href="~/assets/css/pages.css">
    @if (session == null)
    {
        <link rel="stylesheet" href="~/assets/css/auth-modal.css">
    }
    @RenderSection("cssQTY", required: false)
    @RenderSection("cssMessage", required: false)
</head>

<body>
    <div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>
    <div class="toast-container" id="toastContainer"></div>
    <button class="back-to-top" id="backToTop" aria-label="Lên đầu trang">
        <i class="fas fa-chevron-up"></i>
    </button>

    <header class="header">
        <div class="header__top">
            <div class="container">
                <p class="header__top--hotline">
                    Hotline: <a href="tel:0857898971">0857898971</a>
                </p>
                @if (session == null)
                {
                    <p class="header__top--regis">
                        <a href="#" data-auth-open="register">Đăng ký</a>
                    </p>
                    <p class="header__top--login">
                        <a href="#" data-auth-open="login">Đăng nhập</a>
                    </p>
                }
                else
                {
                    <ul class="user__menu">
                        <li class="user__item">
                            @{
                                string ImagePath = "~/assets/Images/AnhDaiDien/" + session.AnhDaiDien;
                            }
                            <img src="@Url.Content(ImagePath)" alt="@session.HoTen" class="user__img">
                            <span class="user__name">@session.HoTen</span>
                            <ul class="user__control">
                                <li class="user__control--item"><a href="@Url.Action("ChangeInfor", "User", new { id = session.UserID })">Tài khoản của tôi</a></li>
                                <li class="user__control--item"><a href="@Url.Action("ChangePassword", "User")">Đổi mật khẩu</a></li>
                                <li class="user__control--item"><a href="@Url.Action("Index", "Invoice", new { id = session.UserID })">Đơn mua</a></li>
                                <li class="user__control--item"><a href="@Url.Action("Logout", "User")">Đăng xuất</a></li>
                            </ul>
                        </li>
                    </ul>
                }
            </div>
        </div>

        <div class="header__middle">
            <div class="container">
                <div class="header__middle--img">
                    <a href="@Url.Action("Index","Home")" class="header__middle--logo">
                        <img src="~/assets/img/logo.png" alt="IMUA Logo">
                    </a>
                    <a href="@Url.Action("Index","Home")" class="header__middle--sologan">
                        <img src="~/assets/img/sologan.png" alt="Mỹ phẩm chính hãng">
                    </a>
                </div>
                <div class="wrapper">
                    <div class="header__middle--search">
                        <div class="header__search--input">
                            @using (Html.BeginForm("Index", "TimKiem"))
                            {
                                <input type="text" placeholder="Tìm kiếm sản phẩm..." id="SearchString" name="SearchString" />
                                <button type="submit" class="header__search--icon" onclick="return valid_search();">
                                    <i class="fas fa-search"></i>
                                </button>
                            }
                            <p class="search-error" id="searchError">Vui lòng nhập từ khóa tìm kiếm</p>
                        </div>
                    </div>
                    <div class="header__middle--cart">
                        <a href="@Url.Action("Index","Cart")" class="header__middle--cart--link">
                            <span class="cart__icon">
                                <i class="fas fa-shopping-basket"></i>
                            </span>
                            @{ Html.RenderAction("CartCount", "Home"); }
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="promo-bar" aria-label="Khuyến mãi">
            <div class="promo-bar__track">
                <span><i class="fas fa-gift"></i> Miễn phí giao hàng đơn từ 500.000đ</span>
                <span><i class="fas fa-percent"></i> Sale off đến 50% — Mua là có quà</span>
                <span><i class="fas fa-shield-alt"></i> Cam kết 100% hàng chính hãng</span>
                <span><i class="fas fa-truck"></i> Giao hàng tận nơi toàn quốc</span>
                <span><i class="fas fa-gift"></i> Miễn phí giao hàng đơn từ 500.000đ</span>
                <span><i class="fas fa-percent"></i> Sale off đến 50% — Mua là có quà</span>
                <span><i class="fas fa-shield-alt"></i> Cam kết 100% hàng chính hãng</span>
                <span><i class="fas fa-truck"></i> Giao hàng tận nơi toàn quốc</span>
            </div>
        </div>

        @{Html.RenderAction("DanhMuc", "Home");}
    </header>

    <main class="content">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer__item">
                <h4>Hỗ trợ khách hàng</h4>
                <p>
                    <a href="@Url.Action("ShoppingGuide", "Home")">Hỗ trợ mua hàng</a>
                    <br>
                    <a href="@Url.Action("ShoppingGuide", "Home")">Chính sách đổi trả</a>
                    <br>
                    <a href="@Url.Action("ShoppingGuide", "Home")">Quy định vận chuyển</a>
                    <br>
                    <a href="@Url.Action("ShoppingGuide", "Home")">Phương thức thanh toán</a>
                    <br>
                    <a href="@Url.Action("Contact", "Home")">Chính sách bảo mật</a>
                </p>
            </div>
            <div class="footer__item">
                <h4>Website thuộc quyền</h4>
                <p>
                    CÔNG TY TNHH HV NET
                    <br>
                    ĐKKD Số: 0313411135
                    <br>
                    Do Sở KH&ĐT Hà Nội
                    <br>
                    Cấp ngày 24/08/2015
                    <br>
                    <a href="http://online.gov.vn/" target="_blank" rel="noopener">
                        <img src="~/assets/img/DangKyBoCongThuong.png" alt="BCT">
                    </a>
                </p>
            </div>
            <div class="footer__item">
                <h4>Trung tâm phân phối</h4>
                <p>
                    Bắc Từ Liêm, Hà Nội
                    <br>
                    Tel: 0857898971 Email: info@imua.com.vn
                    <br>
                    Website: <a href="https://imua.com.vn/" target="_blank" rel="noopener">www.imua.com.vn</a>
                    <br>
                    <a href="https://www.dmca.com/" target="_blank" rel="noopener">
                        <img src="~/assets/img/DMCA_logo-grn-btn150w.png" alt="DMCA">
                    </a>
                    <br>
                    <a href="https://imua.com.vn/" target="_blank" rel="noopener">
                        <img src="~/assets/img/logohvnet.png" alt="HV Net">
                        Được Marketing & Phân phối bởi
                        <span class="footer__brand">HV Net</span>
                    </a>
                </p>
            </div>
            <div class="footer__item">
                <a href="@Url.Action("Contact", "Home")">
                    <img src="~/assets/img/address-shop1.jpg" alt="Cửa hàng IMUA">
                </a>
            </div>
        </div>
        <div class="footer__bottom">
            <div class="container">
                <p class="footer__copyright">&copy; @DateTime.Now.Year IMUA.com.vn — Mỹ phẩm chính hãng. All rights reserved.</p>
                <div class="footer__social">
                    <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    <a href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                    <a href="tel:0857898971" aria-label="Hotline"><i class="fas fa-phone-alt"></i></a>
                </div>
            </div>
        </div>
    </footer>

    @if (session == null)
    {
        @Html.Partial("_AuthModals")
    }

    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/assets/js/jquery.elevateZoom-3.0.8.min.js"></script>
    <script src="~/assets/js/main.js"></script>
    <script src="~/assets/js/animations.js"></script>
    @if (session == null)
    {
        <script src="~/assets/js/auth-modal.js"></script>
    }
    @RenderSection("addMoreCart", required: false)
    @RenderSection("scriptUp", required: false)
    @RenderSection("scriptDel", required: false)
</body>
</html>
