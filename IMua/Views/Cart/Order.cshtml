@{
    ViewBag.Title = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var orderId = ViewBag.OrderId as int?;
    var orderTotal = ViewBag.OrderTotal as decimal?;
    var orderDate = ViewBag.OrderDate as DateTime?;
    var shippingFee = ViewBag.ShippingFee as decimal?;
    var session = (IMua.Common.UserLogin)Session[IMua.Common.CommonConstants.USER_SESSION];
}

<div class="order-success">
    <div class="container">
        <div class="order-success__card reveal">
            <div class="order-success__icon" aria-hidden="true">
                <span class="order-success__check">
                    <i class="fas fa-check"></i>
                </span>
            </div>

            <h1 class="order-success__title">Đặt hàng thành công!</h1>
            <p class="order-success__subtitle">
                Cảm ơn bạn đã tin tưởng và mua sắm tại IMUA. Đơn hàng của bạn đang được xử lý.
            </p>

            @if (orderId.HasValue)
            {
                <div class="order-success__summary">
                    <div class="order-success__row">
                        <span class="order-success__label"><i class="fas fa-receipt"></i> Mã đơn hàng</span>
                        <strong>#@orderId.Value.ToString("D6")</strong>
                    </div>
                    @if (orderDate.HasValue)
                    {
                        <div class="order-success__row">
                            <span class="order-success__label"><i class="fas fa-calendar-alt"></i> Ngày đặt</span>
                            <strong>@orderDate.Value.ToString("dd/MM/yyyy HH:mm")</strong>
                        </div>
                    }
                    @if (shippingFee.HasValue)
                    {
                        <div class="order-success__row">
                            <span class="order-success__label"><i class="fas fa-truck"></i> Phí vận chuyển</span>
                            <strong>@(shippingFee.Value == 0 ? "Miễn phí" : string.Format("{0:c0}", shippingFee.Value))</strong>
                        </div>
                    }
                    @if (orderTotal.HasValue)
                    {
                        <div class="order-success__row order-success__row--total">
                            <span class="order-success__label"><i class="fas fa-money-bill-wave"></i> Tổng thanh toán</span>
                            <strong>@string.Format("{0:c0}", orderTotal.Value)</strong>
                        </div>
                    }
                </div>
            }

            <div class="order-success__steps">
                <div class="order-success__step order-success__step--done">
                    <span class="order-success__step-dot"><i class="fas fa-check"></i></span>
                    <span>Đặt hàng</span>
                </div>
                <div class="order-success__step-line"></div>
                <div class="order-success__step order-success__step--active">
                    <span class="order-success__step-dot">2</span>
                    <span>Xác nhận</span>
                </div>
                <div class="order-success__step-line"></div>
                <div class="order-success__step">
                    <span class="order-success__step-dot">3</span>
                    <span>Giao hàng</span>
                </div>
                <div class="order-success__step-line"></div>
                <div class="order-success__step">
                    <span class="order-success__step-dot">4</span>
                    <span>Thanh toán COD</span>
                </div>
            </div>

            <div class="order-success__note">
                <i class="fas fa-info-circle"></i>
                <p>Chúng tôi sẽ liên hệ xác nhận đơn hàng trong thời gian sớm nhất. Thanh toán khi nhận hàng (COD).</p>
            </div>

            <div class="order-success__actions">
                <a href="@Url.Action("Index", "Home")" class="order-success__btn order-success__btn--outline">
                    <i class="fas fa-shopping-bag"></i> Tiếp tục mua sắm
                </a>
                @if (session != null)
                {
                    <a href="@Url.Action("Index", "Invoice", new { id = session.UserID })" class="order-success__btn order-success__btn--primary">
                        <i class="fas fa-list-alt"></i> Xem đơn hàng
                    </a>
                }
            </div>
        </div>
    </div>
</div>
