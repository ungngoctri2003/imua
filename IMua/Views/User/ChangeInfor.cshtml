@model IMua.Models.NguoiDung

@{
    ViewBag.Title = "Tài khoản của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var session = (IMua.Common.UserLogin)Session[IMua.Common.CommonConstants.USER_SESSION];
    var userId = session?.UserID ?? Model.MaND;
    var avatarUrl = string.IsNullOrEmpty(Model.AnhDaiDien)
        ? Url.Content("~/assets/Images/AnhDaiDien/default-avatar.png")
        : Url.Content("~/assets/Images/AnhDaiDien/" + Model.AnhDaiDien);
}

@section cssMessage {
    <link rel="stylesheet" href="@Url.Content("~/assets/css/account.css?v=20260529")" />
}

<div class="account-page">
    <div class="account-page__hero">
        <div class="container">
            <div class="detail__path breadcrumb">
                <a href="@Url.Action("Index", "Home")">Trang chủ</a>
                <span class="breadcrumb__sep">/</span>
                <span>Tài khoản của tôi</span>
            </div>
            <div class="account-page__hero-content">
                <span class="account-page__badge"><i class="fas fa-leaf"></i> Thành viên IMUA</span>
                <h1 class="account-page__hero-title">Xin chào, @Model.HoTen</h1>
                <p class="account-page__hero-desc">Quản lý thông tin cá nhân, bảo mật tài khoản và theo dõi đơn hàng tại một nơi.</p>
            </div>
        </div>
    </div>

    <div class="container account-page__body">
        <div class="account-layout">
            <aside class="account-sidebar">
                <div class="account-sidebar__profile">
                    <div class="account-sidebar__avatar-ring">
                        <img src="@avatarUrl" alt="@Model.HoTen" class="account-sidebar__avatar" id="sidebarAvatar" />
                    </div>
                    <h2 class="account-sidebar__name">@Model.HoTen</h2>
                    <p class="account-sidebar__username">@@@Model.TenDangNhap</p>
                </div>

                <nav class="account-sidebar__nav" aria-label="Menu tài khoản">
                    <a href="@Url.Action("ChangeInfor", "User", new { id = userId })" class="account-sidebar__link account-sidebar__link--active">
                        <span class="account-sidebar__icon"><i class="fas fa-user-edit"></i></span>
                        <span class="account-sidebar__link-text">
                            <strong>Thông tin cá nhân</strong>
                            <small>Cập nhật hồ sơ</small>
                        </span>
                    </a>
                    <a href="@Url.Action("ChangePassword", "User")" class="account-sidebar__link">
                        <span class="account-sidebar__icon"><i class="fas fa-shield-alt"></i></span>
                        <span class="account-sidebar__link-text">
                            <strong>Đổi mật khẩu</strong>
                            <small>Bảo mật tài khoản</small>
                        </span>
                    </a>
                    <a href="@Url.Action("Index", "Invoice", new { id = userId })" class="account-sidebar__link">
                        <span class="account-sidebar__icon"><i class="fas fa-shopping-bag"></i></span>
                        <span class="account-sidebar__link-text">
                            <strong>Đơn mua</strong>
                            <small>Lịch sử đặt hàng</small>
                        </span>
                    </a>
                    <a href="@Url.Action("Logout", "User")" class="account-sidebar__link account-sidebar__link--logout">
                        <span class="account-sidebar__icon"><i class="fas fa-sign-out-alt"></i></span>
                        <span class="account-sidebar__link-text">
                            <strong>Đăng xuất</strong>
                            <small>Thoát khỏi tài khoản</small>
                        </span>
                    </a>
                </nav>
            </aside>

            <div class="account-main">
                @Html.ValidationSummary(true, "", new { @class = "account-alert" })

                @using (Html.BeginForm("ChangeInfor", "User", FormMethod.Post, new { @class = "account-form", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.MaND)
                    @Html.HiddenFor(model => model.MatKhau)
                    @Html.HiddenFor(model => model.TrangThai)
                    @Html.HiddenFor(model => model.GroupID)
                    @Html.HiddenFor(model => model.TenDangNhap)
                    <input type="hidden" name="Image1" value="@Model.AnhDaiDien" />

                    <section class="account-card account-card--avatar">
                        <div class="account-card__head">
                            <div class="account-card__head-icon"><i class="fas fa-camera-retro"></i></div>
                            <div>
                                <h3>Ảnh đại diện</h3>
                                <p>Ảnh giúp bạn dễ nhận diện trên IMUA</p>
                            </div>
                        </div>

                        <div class="account-avatar-upload">
                            <label for="ufile" class="account-avatar-upload__preview">
                                <img id="output" src="@avatarUrl" alt="Ảnh đại diện" />
                                <span class="account-avatar-upload__overlay">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <span>Chọn ảnh mới</span>
                                </span>
                            </label>
                            <input type="file" name="ImageFile" id="ufile" accept="image/*" hidden onchange="loadFile(event)" />
                            <div class="account-avatar-upload__tips">
                                <p><i class="fas fa-check-circle"></i> Định dạng JPG, PNG hoặc GIF</p>
                                <p><i class="fas fa-check-circle"></i> Kích thước khuyến nghị 400×400px</p>
                                <p><i class="fas fa-check-circle"></i> Dung lượng tối đa 5MB</p>
                            </div>
                        </div>
                    </section>

                    <section class="account-card">
                        <div class="account-card__head">
                            <div class="account-card__head-icon"><i class="fas fa-id-card"></i></div>
                            <div>
                                <h3>Thông tin cá nhân</h3>
                                <p>Thông tin dùng để giao hàng và liên hệ</p>
                            </div>
                        </div>

                        <div class="account-form__grid">
                            <div class="account-field">
                                <label for="HoTen">Họ và tên <span>*</span></label>
                                <div class="account-field__control">
                                    <i class="fas fa-user"></i>
                                    @Html.TextBoxFor(model => model.HoTen, new { @class = "account-field__input", placeholder = "Nguyễn Văn A" })
                                </div>
                                @Html.ValidationMessageFor(model => model.HoTen, "", new { @class = "account-field__error" })
                            </div>

                            <div class="account-field">
                                <label for="Email">Email <span>*</span></label>
                                <div class="account-field__control">
                                    <i class="fas fa-envelope"></i>
                                    @Html.TextBoxFor(model => model.Email, new { @class = "account-field__input", placeholder = "email@example.com", type = "email" })
                                </div>
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "account-field__error" })
                            </div>

                            <div class="account-field">
                                <label for="SoDT">Số điện thoại <span>*</span></label>
                                <div class="account-field__control">
                                    <i class="fas fa-phone-alt"></i>
                                    @Html.TextBoxFor(model => model.SoDT, new { @class = "account-field__input", placeholder = "09xx xxx xxx" })
                                </div>
                                @Html.ValidationMessageFor(model => model.SoDT, "", new { @class = "account-field__error" })
                            </div>

                            <div class="account-field">
                                <label for="TenDangNhap">Tên đăng nhập</label>
                                <div class="account-field__control account-field__control--readonly">
                                    <i class="fas fa-at"></i>
                                    <input type="text" class="account-field__input" value="@Model.TenDangNhap" readonly />
                                </div>
                                <span class="account-field__hint">Tên đăng nhập không thể thay đổi</span>
                            </div>

                            <div class="account-field account-field--full">
                                <label for="DiaChi">Địa chỉ giao hàng <span>*</span></label>
                                <div class="account-field__control">
                                    <i class="fas fa-map-marker-alt"></i>
                                    @Html.TextBoxFor(model => model.DiaChi, new { @class = "account-field__input", placeholder = "Số nhà, đường, quận/huyện, tỉnh/thành phố" })
                                </div>
                                @Html.ValidationMessageFor(model => model.DiaChi, "", new { @class = "account-field__error" })
                            </div>
                        </div>
                    </section>

                    <div class="account-form__footer">
                        <div class="account-form__note">
                            <i class="fas fa-info-circle"></i>
                            <p>Thông tin của bạn được bảo mật và chỉ dùng để xử lý đơn hàng tại IMUA.</p>
                        </div>
                        <div class="account-form__actions">
                            <a href="@Url.Action("Index", "Home")" class="account-btn account-btn--ghost">Hủy</a>
                            <button type="submit" class="account-btn account-btn--primary">
                                <i class="fas fa-save"></i>
                                Lưu thay đổi
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (ViewBag.Success != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof showToast === "function") {
                showToast("@ViewBag.Success", "success");
            }
        });
    </script>
}

<script>
    var loadFile = function (event) {
        var file = event.target.files[0];
        if (!file) return;

        var previewUrl = URL.createObjectURL(file);
        document.getElementById("output").src = previewUrl;

        var sidebarAvatar = document.getElementById("sidebarAvatar");
        if (sidebarAvatar) {
            sidebarAvatar.src = previewUrl;
        }
    };
</script>
